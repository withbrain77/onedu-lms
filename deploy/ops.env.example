# Optional local helper variables for deploy/remote-compose.sh.
# Do not put passwords here. Use SSH keys or ~/.ssh/config instead.

ONEDU_SSH_TARGET=onedu-nas
ONEDU_APP_DIR=/volume1/wbinstitute/docker/onedu/app
ONEDU_COMPOSE_PROJECT=onedu
ONEDU_DOCKER_COMPOSE=docker compose
# If your NAS user gets "permission denied" for /var/run/docker.sock, use:
# ONEDU_DOCKER_COMPOSE=sudo docker compose
ONEDU_BASE_URL=http://127.0.0.1:8080
ONEDU_HTTP_HOST=192.168.0.97
