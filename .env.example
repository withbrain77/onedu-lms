# Django
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=change-this-to-a-long-random-secret-key-before-production
DJANGO_ALLOWED_HOSTS=lms.example.com,nas.example.com,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://lms.example.com,https://nas.example.com
DJANGO_PUBLIC_SITE_URL=https://lms.example.com

# HTTPS/security.
# If HTTPS termination is handled by Synology Reverse Proxy, keep Nginx on HTTP
# and make sure Synology forwards X-Forwarded-Proto: https.
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_USE_X_FORWARDED_HOST=True

# PostgreSQL
POSTGRES_DB=onedu
POSTGRES_USER=onedu
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=600
# DATABASE_URL=postgres://onedu:change-this-postgres-password@db:5432/onedu

# Storage paths inside containers
STATIC_ROOT=/vol/web/static
MEDIA_ROOT=/vol/web/media
PRIVATE_MEDIA_ROOT=/vol/web/private_media

# Synology/NAS host bind-mount paths. Replace with your NAS folders.
ONEDU_DB_DIR=./data/postgres
ONEDU_STATIC_DIR=./data/static
ONEDU_MEDIA_DIR=./data/media
ONEDU_PRIVATE_MEDIA_DIR=./data/private_media
ONEDU_REDIS_DIR=./data/redis

# Certificates/PDF
CERTIFICATE_ISSUER_NAME=Onedu LMS
CERTIFICATE_FONT_PATH=/usr/share/fonts/truetype/nanum/NanumGothic.ttf

# Protected private video serving
USE_X_ACCEL_REDIRECT=True
X_ACCEL_REDIRECT_PREFIX=/protected-media/

# Background HLS conversion queue
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_VIDEO_QUEUE=video
CELERY_WORKER_CONCURRENCY=1
CELERY_EXPIRY_NOTICE_HOUR=9
CELERY_EXPIRY_NOTICE_MINUTE=0

# Email for password reset links
DJANGO_DEFAULT_FROM_EMAIL=Onedu LMS <no-reply@example.com>
DJANGO_SERVER_EMAIL=Onedu LMS <no-reply@example.com>
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=no-reply@example.com
DJANGO_EMAIL_HOST_PASSWORD=change-this-email-password
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_EMAIL_TIMEOUT=30
ONEDU_EMAIL_RETRY_COUNT=3
ONEDU_EMAIL_RETRY_DELAY_SECONDS=10
ONEDU_EMAIL_ASYNC=True
ONEDU_NOTIFY_ENROLLMENT_REQUEST=True
ONEDU_NOTIFY_ENROLLMENT_APPROVAL=True
ONEDU_NOTIFY_ENROLLMENT_EXPIRY_7D=True
# If this is empty, the LMS uses DJANGO_EMAIL_HOST_USER as the default admin recipient.
ONEDU_ADMIN_NOTIFICATION_EMAIL=admin@example.com
ONEDU_DEPOSIT_BANK=국민은행
ONEDU_DEPOSIT_ACCOUNT=700101-01-323177
ONEDU_DEPOSIT_HOLDER=표진호(위드브레인)
ONEDU_DEPOSIT_PAYER_NOTE=수강생 이름과 동일하게 입력해 주세요.
ONEDU_ACCESS_LOG_ENABLED=True
ONEDU_ACCESS_LOG_CONCURRENCY_WINDOW_MINUTES=15
ONEDU_SERVER_STATUS_DOMAIN=lms.example.com
ONEDU_PUBLIC_IP_CHECK_URL=https://api.ipify.org
ONEDU_SERVER_STATUS_TIMEOUT_SECONDS=1.0
ONEDU_LOG_DIR_HOST=./data/logs
ONEDU_LOG_DIR=/vol/web/logs
ONEDU_LOG_LEVEL=INFO
ONEDU_LOG_MAX_BYTES=5242880
ONEDU_LOG_BACKUP_COUNT=5

# Nginx
NGINX_HTTP_PORT=8080

# Startup toggles
DJANGO_WAIT_FOR_DB=1
DJANGO_RUN_MIGRATIONS=1
DJANGO_COLLECTSTATIC=1
